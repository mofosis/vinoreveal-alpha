rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL
    //
    // Collection: sessions
    // Fields: id, name, createdBy, createdAt, participants (array), activeWineId, status
    //
    // Collection: sessions/{sessionId}/wines
    // Fields: id, sessionId, name, label, order, revealed, analysis
    //
    // Collection: sessions/{sessionId}/ratings
    // Fields: userId, userName, wineId, sessionId, score, comment, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "martinmosteil@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'email', 'photoURL', 'role']) &&
             data.uid is string && data.displayName is string && data.displayName.size() < 100;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['name', 'createdBy', 'createdAt', 'participants', 'shortId']) &&
             data.name is string && data.name.size() < 100 &&
             data.participants is list && data.participants.size() < 50 &&
             data.shortId is string && data.shortId.size() == 2;
    }

    function isValidWine(data) {
      return data.keys().hasAll(['name', 'sessionId', 'order']) &&
             data.name is string && data.name.size() < 200 &&
             (!('grapeVariety' in data) || data.grapeVariety is string || data.grapeVariety == null) &&
             (!('price' in data) || data.price is number || data.price == null);
    }

    function isValidRating(data) {
      return data.keys().hasAll(['userId', 'wineId', 'sessionId', 'score']) &&
             data.score is number && data.score >= 0 && data.score <= 10 &&
             data.userId == request.auth.uid &&
             (!('comment' in data) || data.comment is string || data.comment == null) &&
             (!('guessedGrapeVariety' in data) || data.guessedGrapeVariety is string || data.guessedGrapeVariety == null) &&
             (!('guessedPrice' in data) || data.guessedPrice is number || data.guessedPrice == null);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'createdAt', 'anonymousName']) &&
             data.text is string && data.text.size() < 500 &&
             data.anonymousName is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /sessions/{sessionId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSession(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Allow users to join
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']) && 
         request.resource.data.participants.hasAll(resource.data.participants) && 
         request.auth.uid in request.resource.data.participants) ||
        // Allow creator to update everything
        (resource.data.createdBy == request.auth.uid) ||
        isAdmin()
      );
      
      match /wines/{wineId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && (get(/databases/$(database)/documents/sessions/$(sessionId)).data.createdBy == request.auth.uid || isAdmin());
      }

      match /ratings/{ratingId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidRating(request.resource.data);
        allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidRating(request.resource.data);
      }

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      }
    }
  }
}
